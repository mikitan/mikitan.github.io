import React, { useState } from 'react';

const PROMPT_FORGE = () => {
  const [selectedEp, setSelectedEp] = useState("EP01");
  const basePrompt = "(Masterpiece:1.2), Cinematic lighting, icy white hair, glowing neon cyan eyes, mysterious smile, dark midnight blue futuristic city background";
  const negativePrompt = "(lowres, bad anatomy, blurry, watermark, text, bad hands, extra fingers, deformed)";
  const motionPrompt = "(gentle hair flowing in the wind, eyes blinking, minimal movement)";

  // エピソードごとの追加プロンプト
  const epPrompts = {
    "EP01": "Cyberpunk city street walking, neon lights reflections",
    "EP02": "Rainy night, trench coat, melancholy atmosphere",
    "EP06": "Looking into a mirror, reflection in the corridor",
    "EP09": "Advanced battle suit, combat stance, energy sparks"
  };

  const fullPrompt = `${basePrompt}, ${epPrompts[selectedEp]}, high quality, 8k resolution`;

  const copyToClipboard = (text) => {
    navigator.clipboard.writeText(text);
    alert("クリップボードにコピーしました！");
  };

  return (
    <div style={{ padding: '20px', backgroundColor: '#0a0a12', color: '#fff' }}>
      <h1>AURA PROMPT FORGE</h1>
      {/* エピソード選択 */}
      <div style={{ marginBottom: '20px' }}>
        {Object.keys(epPrompts).map(ep => (
          <button key={ep} onClick={() => setSelectedEp(ep)} style={{ marginRight: '10px', background: selectedEp === ep ? '#00D4FF' : '#333', color: 'white', border: 'none', padding: '10px' }}>{ep}</button>
        ))}
      </div>
      {/* 出力エリア */}
      <div style={{ display: 'grid', gap: '20px' }}>
        <div>
          <h3>生成プロンプト</h3>
          <textarea readOnly value={fullPrompt} style={{ width: '100%', height: '80px' }} />
          <button onClick={() => copyToClipboard(fullPrompt)}>Copy Prompt</button>
        </div>
        <div style={{ display: 'flex', gap: '10px' }}>
          <button onClick={() => copyToClipboard(negativePrompt)}>Copy Negative Prompt</button>
          <button onClick={() => copyToClipboard(motionPrompt)}>Copy Motion Prompt</button>
        </div>
      </div>
    </div>
  );
};

export default PROMPT_FORGE;
