import os
from PIL import Image
import math

def create_grid(image_folder, output_path, cols=4):
    # .pngファイルのみを取得
    images = [f for f in os.listdir(image_folder) if f.endswith('.png')]
    images.sort()
    
    if not images:
        return

    # 最初の画像からサイズを取得
    first_img = Image.open(os.path.join(image_folder, images[0]))
    w, h = first_img.size
    
    # グリッドの行数を計算
    rows = math.ceil(len(images) / cols)
    
    # 出力用の真っ白なキャンバスを作成
    grid_img = Image.new('RGB', (cols * w, rows * h), (255, 255, 255))
    
    for index, img_name in enumerate(images):
        img = Image.open(os.path.join(image_folder, img_name))
        # 適切な位置に貼り付け
        x = (index % cols) * w
        y = (index // cols) * h
        grid_img.paste(img, (x, y))
        
    grid_img.save(output_path)
    print(f"Saved grid image to {output_path}")

