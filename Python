from flask import Flask, jsonify
import os

app = Flask(__name__)

# トップページの設定（index.htmlを使わず、直接文字を出す）
@app.route('/')
def index():
    return "<h1>AI Server is Live!</h1><p>予測データは /v1/predict へ</p>"

# 予測データの設定
@app.route('/v1/predict')
def predict():
    return jsonify({
        "status": "success",
        "prediction": "Bullish",
        "accuracy": "89.4%"
    })

if __name__ == "__main__":
    port = int(os.environ.get("PORT", 5000))
    app.run(host='0.0.0.0', port=port)
