import requests
import datetime

# --- 設定（自分のIDを入れる） ---
RAKUTEN_APP_ID = 'あなたのアプリID' # 楽天ウェブサービスで取得
AFFILIATE_ID = 'あなたのアフィリエイトID'
SEARCH_KEYWORD = 'DTM 機材' # 稼ぎたいジャンル

def get_rakuten_items():
    url = f"https://app.rakuten.co.jp/services/api/IchibaItem/Search/20170706?format=json&keyword={SEARCH_KEYWORD}&applicationId={RAKUTEN_APP_ID}&affiliateId={AFFILIATE_ID}&hits=5&sort=-updateTimestamp"
    res = requests.get(url)
    if res.status_code == 200:
        return res.json()['Items']
    return []

def generate_html(items):
    now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    item_html = ""
    for i in items:
        item = i['Item']
        item_html += f'''
        <div class="item">
            <img src="{item['mediumImageUrls'][0]['imageUrl']}" alt="{item['itemName']}">
            <h3><a href="{item['affiliateUrl']}" target="_blank">{item['itemName']}</a></h3>
            <p class="price">価格: {item['itemPrice']}円</p>
        </div>'''

    html_content = f'''
    <!DOCTYPE html>
    <html lang="ja">
    <head>
        <meta charset="UTF-8">
        <title>Micvictory - 自動更新セレクトショップ</title>
        <style>
            body {{ font-family: sans-serif; background: #f4f4f4; text-align: center; }}
            .item {{ background: white; margin: 10px auto; padding: 20px; max-width: 500px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }}
            img {{ max-width: 150px; }}
            .price {{ color: #e4393c; font-weight: bold; }}
        </style>
    </head>
    <body>
        <h1>Micvictory Select Shop</h1>
        <p>最終更新: {now}</p>
        {item_html}
    </body>
    </html>
    '''
    with open('index.html', 'w', encoding='utf-8') as f:
        f.write(html_content)

if __name__ == "__main__":
    items = get_rakuten_items()
    generate_html(items)

