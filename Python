# --- 2. Geminiで「戦略的記事」を生成する関数 ---
def generate_article_html():
    # モデルを最新の 1.5-flash に指定
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={GEMINI_API_KEY}"
    
    # 【1.2 付け足し】プロンプトにブランド戦略を組み込む
    prompt = f"""
    テーマ: {SITE_KW}
    ブランド名: MICVICTORY POME. (ミックビクトリー・ポメ)
    
    以下のリンクを必ず含めて、戦略的なアピール記事をHTML形式で作成してください。
    - 最新PDFカタログ: {CATALOG_URL}
    - カスタム相談窓口: {CONSULTING_URL}
    
    【構成要件】
    1. 「堺の職人魂 × Pythonによる自動化」がいかに成功を生むかの論理的説明。
    2. 2026年サマーコレクション（デニム羽織、ジュエリー）の紹介。
    3. 読者の「成功」を鼓舞する情熱的な口調（河内音頭のような勢い）。
    4. <body>タグ内のみ出力。デザインは「紺(Navy)」と「金(Gold)」を基調にすること。
    """

    payload = {"contents": [{"parts": [{"text": prompt}]}]}
    try:
        response = requests.post(url, json=payload)
        article_content = response.json()['candidates'][0]['content']['parts'][0]['text']
        # Markdownのデコレーション(```html等)を削除するクリーンアップ
        article_content = article_content.replace('```html', '').replace('```', '')
        return article_content
    except Exception as e:
        print(f"記事生成エラー: {e}")
        return None

