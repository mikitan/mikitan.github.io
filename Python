def upload_to_fc2(article_html: str):
    filename = "index.html"
    try:
        full_page = f"""<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{BRAND_NAME} | 堺の魂を纏う</title>
    <style>
        body {{ background-color: #1a2a44; color: #f0f0f0; font-family: sans-serif; line-height: 1.85; }}
        a {{ color: #d4af37; font-weight: bold; text-decoration: none; }}
        a:hover {{ text-decoration: underline; }}
        .container {{ max-width: 860px; margin: 50px auto; padding: 50px 40px; border: 3px solid #d4af37; background: rgba(26, 42, 68, 0.97); }}
        h1, h2 {{ color: #d4af37; }}
        hr {{ border-color: #d4af37; }}
    </style>
</head>
<body>
    <div class="container">
        {article_html}
        <hr>
        <p style="text-align: center; color: #aaa; font-size: 0.95em;">
            Automated Update: {datetime.now().strftime('%Y年%m月%d日 %H:%M')} JST
        </p>
    </div>
</body>
</html>"""

        with open(filename, "w", encoding="utf-8") as f:
            f.write(full_page)

        # FTPアップロード
        with FTP_TLS(FTP_HOST) as ftps:
            ftps.login(FTP_USER, FTP_PASS)
            ftps.prot_p()
            with open(filename, "rb") as f:
                ftps.storbinary(f"STOR {filename}", f)

        print(f"✅ {filename} をサーバーにアップロードしました ({datetime.now().strftime('%H:%M')})")
    except Exception as e:
        print(f"❌ FTPアップロード失敗: {e}")


# ====================== 3. ニュースまとめ ======================
def generate_news_md() -> str:
    # （前回版とほぼ同じで簡略化）
    rss_list = [
        "https://news.yahoo.co.jp/rss/topics/top-picks.xml",
        "https://news.yahoo.co.jp/rss/topics/domestic.xml",
        "https://news.yahoo.co.jp/rss/topics/world.xml",
        "https://rss.itmedia.co.jp/rss/2.0/news_bursts.xml",
    ]

    articles = []
    seen = set()
    for url in rss_list:
        try:
            feed = feedparser.parse(url)
            for entry in feed.entries[:10]:
                if entry.link in seen: continue
                seen.add(entry.link)
                articles.append({
                    "title": entry.title,
                    "link": entry.link,
                    "summary": entry.get("summary") or entry.get("description", "")
                })
        except:
            continue

    md = f"# 📰 本日のニュース\n**{datetime.now().strftime('%Y年%m月%d日 %H:%M')} JST**\n\n---\n\n"
    for art in articles[:20]:
        summary = (art["summary"][:150] + "...") if len(art["summary"]) > 150 else art["summary"]
        md += f"- **{art['title']}**\n"
        if summary:
            md += f"  {summary}\n"
        md += f"  [詳細]({art['link']})\n\n"
    
    return md


