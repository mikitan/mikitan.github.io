import os
import feedparser
import requests
from datetime import datetime
import google.generativeai as genai

# --- 1. 各種設定（GitHub Secrets等から読み込み） ---
genai.configure(api_key=os.environ.get("GEMINI_API_KEY"))
model = genai.GenerativeModel('gemini-1.5-flash')

RAKUTEN_APP_ID = os.environ.get('RAKUTEN_APP_ID', 'あなたの楽天アプリID')
A8_AD_CODE = 'A8.netの広告コード（ここを書き換えてください）'

RSS_URLS = [
    "https://news.google.com/rss/search?q=IT+news+japan&hl=ja&gl=JP&ceid=JP:ja",
    "https://news.google.com/rss/search?q=アニメ+最新&hl=ja&gl=JP&ceid=JP:ja"
]

# --- 2. 収益化ロジック（楽天API連携） ---
def get_rakuten_item(keyword):
    """ニュースのキーワードに連動した商品を1つ取得し、HTMLカードを返す"""
    url = "https://app.rakuten.co.jp/services/api/IchibaItem/Search/20170706"
    params = {
        "format": "json",
        "applicationId": RAKUTEN_APP_ID,
        "keyword": keyword,
        "hits": 1,
        "sort": "affiliateRate",
    }
    try:
        response = requests.get(url, params=params)
        data = response.json()
        if "Items" in data and len(data["Items"]) > 0:
            item = data["Items"][0]["Item"]
            # 商品カードのHTML生成
            return f"""
            <div style="border: 2px solid #daa520; padding: 15px; border-radius: 10px; margin-top: 30px; background: #fffcf0;">
                <p style="font-size: 0.9em; color: #b8860b; font-weight: bold; margin-bottom: 10px;">▼ この記事に関連するおすすめ資産</p>
                <div style="display: flex; align-items: center;">
                    <img src="{item['mediumImageUrls'][0]['imageUrl']}" style="width: 100px; margin-right: 15px; border-radius: 5px;">
                    <a href="{item['affiliateUrl']}" target="_blank" style="text-decoration: none; color: #333; font-weight: bold; font-size: 1.1em;">{item['itemName']}</a>
                </div>
            </div>
            """
    except Exception as e:
        print(f"楽天API取得エラー: {e}")
    return ""

# --- 3. ニュース取得と要約生成 ---
def generate_report():
    # ニュースの取得
    news_list = []
    for url in RSS_URLS:
        feed = feedparser.parse(url)
        for entry in feed.entries[:2]: # 各ジャンル2件
            news_list.append(f"タイトル: {entry.title}\n要約: {entry.summary if 'summary' in entry else entry.title}")
    
    news_content = "\n\n".join(news_list)

    # Geminiによる戦略的分析
    prompt = f"""
    あなたはITと投資の戦略家です。以下のニュースを読み、「micvictory value world」の読者に向けた戦略レポートを作成してください。
    
    【ニュース】
    {news_content}
    
    【構成要件】
    1. ニュースの鋭い分析（IT・アニメの動向）
    2. 投資と未来へのヒント（河内音頭の情熱を込めて）
    3. 読者が取るべきアクションプラン
    4. 結びの言葉（BandLabの楽曲制作に触れる）
    
    ※HTML形式ではなく、Markdown形式の本文を出力してください。
    """
    
    response = model.generate_content(prompt)
    report_body = response.text
    
    # 代表的なキーワードで楽天商品を検索（ニュースタイトルから抽出）
    search_keyword = news_list[0].split(':')[1].strip()[:10] if news_list else "IT 投資"
    rakuten_html = get_rakuten_item(search_keyword)
    
    # 最終的なコンテンツの組み立て
    today = datetime.now().strftime('%Y-%m-%d')
    full_markdown = f"""
# {today} の戦略レポート

{report_body}

---

## 💡 収益化・支援セクション

<div style="text-align: center; margin: 30px 0;">
    <p style="font-size: 0.8em; color: #888;">スポンサーリンク</p>
    {A8_AD_CODE}
</div>

{rakuten_html}

---
[戦略的分艦（FC2）へ移動](https://mikivaluejapan.web.fc2.com/)
"""
    return full_markdown, today

# --- 4. 実行と保存 ---
if __name__ == "__main__":
    content, date_str = generate_report()
    
    os.makedirs("posts", exist_ok=True)
    file_path = f"posts/{date_str}.md"
    
    with open(file_path, "w", encoding="utf-8") as f:
        f.write(content)
        
    print(f"レポート生成完了: {file_path}")
