# ====================== 3. 画像グリッド作成 ======================
def create_grid(image_folder: str, output_path: str, cols: int = 4):
    images = [f for f in os.listdir(image_folder) if f.lower().endswith('.png')]
    images.sort()
    
    if not images:
        print("画像が見つかりません")
        return

    first = Image.open(os.path.join(image_folder, images[0]))
    w, h = first.size
    rows = math.ceil(len(images) / cols)

    grid = Image.new('RGB', (cols * w, rows * h), (255, 255, 255))

    for idx, img_name in enumerate(images):
        img = Image.open(os.path.join(image_folder, img_name))
        x = (idx % cols) * w
        y = (idx // cols) * h
        grid.paste(img, (x, y))

    grid.save(output_path)
    print(f"✅ グリッド画像保存完了: {output_path}")


