# ====================== 1. Gemini記事生成 ======================
def generate_article_html() -> str | None:
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={GEMINI_API_KEY}"
    
    prompt = f"""
あなたはMICVICTORY POME.の公式ストーリーテラーです。
ブランド名: MICVICTORY POME. (ミックビクトリー・ポメ)
テーマ: {SITE_KW}

以下のリンクを必ず自然に含めて、情熱的で説得力のある戦略記事を**<body>タグ内のみ**のHTMLで作成してください。

- 最新PDFカタログ: {CATALOG_URL}
- カスタム相談窓口: {CONSULTING_URL}

【必須構成】
1. 堺の職人魂 × Python自動化がもたらす競争優位性の論理的説明
2. 2026年サマーコレクション（デニム羽織、ジュエリー）の魅力紹介
3. 読者の「成功」を鼓舞する、河内音頭のような熱い語り口
4. 全体のデザインはNavy(#1a2a44)とGold(#d4af37)を基調

出力はHTML装飾のみ。```html などのマークダウンは絶対に付けないでください。
"""

    payload = {"contents": [{"parts": [{"text": prompt}]}]}
    
    try:
        response = requests.post(url, json=payload, timeout=30)
        response.raise_for_status()
        data = response.json()
        article = data['candidates'][0]['content']['parts'][0]['text']
        # クリーニング
        article = article.replace('```html', '').replace('```', '').strip()
        return article
    except Exception as e:
        print(f"❌ Gemini記事生成エラー: {e}")
        return None


