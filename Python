    5. HTMLのメタディスクリプション用の要約（3行以内）を冒頭に置く
    """
    
    response = model.generate_content(prompt)
    return response.text
import os

def update_index():
    posts_dir = "posts"
    files = sorted([f for f in os.listdir(posts_dir) if f.endswith(".md")], reverse=True)
    
    links_html = "<ul>\n"
    for f in files:
        title = f.replace(".md", "").replace("article-", "")
        links_html += f'  <li><a href="posts/{f}">{title} - 最新戦略レポート</a></li>\n'
    links_html += "</ul>"
    
    # index.html の特定のコメントの間にリンクを挿入
    with open("index.html", "r", encoding="utf-8") as f:
        content = f.read()
    
    start_tag = ""
    end_tag = ""
    
    new_content = content.split(start_tag)[0] + start_tag + "\n" + links_html + "\n" + end_tag + content.split(end_tag)[1]
    
    with open("index.html", "w", encoding="utf-8") as f:
        f.write(new_content)

if __name__ == "__main__":
    update_index()

