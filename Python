import os
import requests
import json
from datetime import datetime
from ftplib import FTP_TLS # 安全な暗号化通信を使用

# --- 1. 設定（あなたの情報に書き換えてください） ---
GEMINI_API_KEY = "あなたのGemini APIキー"
# FTP接続情報
FTP_HOST = "ご自身のFTPホスト名"  # 例: user.web.fc2.com
FTP_USER = "ユーザー名"
FTP_PASS = "パスワード"

# ターゲットサイトの設定
SITE_KW = "AI・最新ガジェット・Web開発"
AFF_TAG = "あなたの楽天・A8等のアフィリエイトリンク"

# --- 2. Geminiで記事（HTML）を生成する関数 ---
def generate_article_html():
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={GEMINI_API_KEY}"
    
    prompt = f"""
    テーマ: {SITE_KW}
    アフィリエイトブログ記事をHTML形式で作成してください。
    必ず以下の広告タグを自然な形で含めてください。
    広告タグ: {AFF_TAG}
    
    【要件】
    - <body>タグの内側のみを出力してください。
    - デザインは黒を基調としたクールなスタイルにしてください。
    - 情熱的な口調（河内音頭のような熱量）を少し混ぜてください。
    """

    payload = {"contents": [{"parts": [{"text": prompt}]}]}
    try:
        response = requests.post(url, json=payload)
        # Geminiの回答からテキストを抽出
        article_content = response.json()['candidates'][0]['content']['parts'][0]['text']
        return article_content
    except Exception as e:
        print(f"記事生成エラー: {e}")
        return None

# --- 3. サーバーにアップロード（書き込み）する関数 ---
def upload_to_fc2(html_content):
    filename = "index.html" # サーバー上のファイル名
    
    # 一時的にスマホ内に保存
    with open(filename, "w", encoding="utf-8") as f:
        # 簡易的なHTMLテンプレートに流し込む
        full_html = f"""<!DOCTYPE html>
<html lang="ja">
<head><meta charset="UTF-8"><title>Strategic Report</title></head>
<body style="background-color: #1a1a1a; color: #ffffff; padding: 20px;">
{html_content}
<hr>
<p>Updated: {datetime.now().strftime('%Y-%m-%d %H:%M')}</p>
</body>
</html>"""
        f.write(full_html)

    # FTP転送（暗号化通信）
    try:
        print(f"{FTP_HOST} に接続中...")
        with FTP_TLS(FTP_HOST) as ftps:
            ftps.login(user=FTP_USER, passwd=FTP_PASS)
            ftps.prot_p() # 通信を暗号化
            
            with open(filename, "rb") as f:
                ftps.storbinary(f"STOR {filename}", f)
            
            print(f"成功: {filename} を更新しました。")
    except Exception as e:
        print(f"FTP転送エラー: {e}")

# --- 4. 実行 ---
if __name__ == "__main__":
    print("記事を生成しています...")
    new_article = generate_article_html()
    
    if new_article:
        print("サーバーへアップロードを開始します...")
        upload_to_fc2(new_article)
