import os
import requests
import base64
from datetime import datetime
import google.generativeai as genai

# 設定 (ご主人様の環境に合わせて)
GITHUB_TOKEN = os.getenv("GITHUB_TOKEN")
REPO_NAME = "mikitan/mikitan.github.io"
GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")

def generate_article():
    genai.configure(api_key=GEMINI_API_KEY)
    model = genai.GenerativeModel('gemini-pro')
    
    prompt = "2026年の資産構築とAI自動化に関する専門的なブログ記事を日本語で生成して。Markdown形式で。"
    response = model.generate_content(prompt)
    return response.text

def commit_to_github(content):
    date_str = datetime.now().strftime("%Y%m%d-%H%M")
    file_path = f"posts/article-{date_str}.md"
    url = f"https://api.github.com/repos/{REPO_NAME}/contents/{file_path}"
    
    headers = {
        "Authorization": f"token {GITHUB_TOKEN}",
        "Accept": "application/vnd.github.v3+json"
    }
    
    # 内容をBase64エンコード
    content_base64 = base64.b64encode(content.encode()).decode()
    
    data = {
        "message": f"Auto-post: {date_str}",
        "content": content_base64,
        "branch": "main"
    }
    
    res = requests.put(url, headers=headers, json=data)
    if res.status_code == 201:
        print(f"成功: {file_path} をコミットしました。")
    else:
        print(f"失敗: {res.json()}")

if __name__ == "__main__":
    article = generate_article()
    commit_to_github(article)
