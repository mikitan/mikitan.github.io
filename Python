def generate_strategic_content():
    """安全フィルターを回避し、エラー時もサイトを維持する修正版"""
    
    # 安全設定をすべて「ブロックしない」に緩和
    safety_settings = [
        {"category": "HARM_CATEGORY_HARASSMENT", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_HATE_SPEECH", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_DANGEROUS_CONTENT", "threshold": "BLOCK_NONE"},
    ]

    prompt = f"""
    あなたは「micvictory value world」の戦略顧問です。
    {TARGET_FILE}のメインコンテンツとして、2026年の「未来予測」と「資産構築」に関する
    リッチなHTML（body内のみ）を日本語で生成してください。

    【必須要素】
    1. AI自動化、e-fuel、伝統文化の資産化のいずれかに関する鋭い洞察。
    2. [micvictory FC2分艦](https://mikivaluejapan.web.fc2.com/) への戦略的誘導リンク。
    3. 社会に役立つ未来予測と、リピーターが喜ぶ具体的なアクションプラン。
    4. 結びに「Goshujin-sama」の制作した BandLab 楽曲へのリスペクトを含める。
    5. 清潔感と高級感のあるデザインを意識したHTML構造。
    """

    try:
        # 生成実行
        response = model.generate_content(prompt, safety_settings=safety_settings)

        # 回答があるかチェック
        if response.candidates and len(response.candidates) > 0:
            # 正常にテキストが取れる場合
            try:
                return response.text
            except ValueError:
                # 途中でブロックされた場合の予備テキスト
                return "<div>2026年戦略を再構成中... 次回の更新をお待ちください。</div>"
        
        # candidatesが空の場合の回避策
        return "<div>現在、最新の未来予測データを解析中です。</div>"

    except Exception as e:
        print(f"生成エラー: {e}")
        return "<div>システムは稼働中です。更新をお待ちください。</div>"

import os
import feedparser
import google.generativeai as genai
from datetime import datetime

# 1. 初期設定（GitHub Secretsに登録したAPIキーを使用）
genai.configure(api_key=os.environ["GEMINI_API_KEY"])
model = genai.GenerativeModel('gemini-1.5-flash')

# 2. ニュース取得（IT・アニメ等のRSS）
RSS_URLS = [
    "https://news.google.com/rss/search?q=IT+news+japan&hl=ja&gl=JP&ceid=JP:ja",
    "https://news.google.com/rss/search?q=アニメ+最新&hl=ja&gl=JP&ceid=JP:ja"
]

def get_latest_news():
    news_items = []
    for url in RSS_URLS:
        feed = feedparser.parse(url)
        for entry in feed.entries[:3]: # 各ジャンル3件
            news_items.append(f"タイトル: {entry.title}\nリンク: {entry.link}")
    return "\n".join(news_items)

# 3. Geminiによる要約と未来予測（あなたの口調を指示）
news_content = get_latest_news()
prompt = f"""
あなたはIT技術と投資に精通した「戦略家（ストラテジスト）」です。
以下のニュースを読み、国民が未来に希望を持てるような、鋭くも温かい口調で要約してください。

【ニュース内容】
{news_content}

【出力構成】
1. 今日の重要IT・アニメニュース（要約）
2. 投資と未来へのヒント（成功への戦略）
3. 一言メッセージ（河内音頭の心や情熱を込めて）
"""

response = model.generate_content(prompt)

# 4. Markdownファイルとして保存
today = datetime.now().strftime('%Y-%m-%d')
file_path = f"posts/{today}.md"
os.makedirs("posts", exist_ok=True)

with open(file_path, "w", encoding="utf-8") as f:
    f.write(f"# {today} の戦略レポート\n\n")
    f.write(response.text)

print(f"Report generated: {file_path}")



