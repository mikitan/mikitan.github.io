def generate_strategic_content():
    """安全フィルターを回避し、エラー時もサイトを維持する修正版"""
    
    # 安全設定をすべて「ブロックしない」に緩和
    safety_settings = [
        {"category": "HARM_CATEGORY_HARASSMENT", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_HATE_SPEECH", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT", "threshold": "BLOCK_NONE"},
        {"category": "HARM_CATEGORY_DANGEROUS_CONTENT", "threshold": "BLOCK_NONE"},
    ]

    prompt = f"""
    あなたは「micvictory value world」の戦略顧問です。
    {TARGET_FILE}のメインコンテンツとして、2026年の「未来予測」と「資産構築」に関する
    リッチなHTML（body内のみ）を日本語で生成してください。

    【必須要素】
    1. AI自動化、e-fuel、伝統文化の資産化のいずれかに関する鋭い洞察。
    2. [micvictory FC2分艦](https://mikivaluejapan.web.fc2.com/) への戦略的誘導リンク。
    3. 社会に役立つ未来予測と、リピーターが喜ぶ具体的なアクションプラン。
    4. 結びに「Goshujin-sama」の制作した BandLab 楽曲へのリスペクトを含める。
    5. 清潔感と高級感のあるデザインを意識したHTML構造。
    """

    try:
        # 生成実行
        response = model.generate_content(prompt, safety_settings=safety_settings)

        # 回答があるかチェック
        if response.candidates and len(response.candidates) > 0:
            # 正常にテキストが取れる場合
            try:
                return response.text
            except ValueError:
                # 途中でブロックされた場合の予備テキスト
                return "<div>2026年戦略を再構成中... 次回の更新をお待ちください。</div>"
        
        # candidatesが空の場合の回避策
        return "<div>現在、最新の未来予測データを解析中です。</div>"

    except Exception as e:
        print(f"生成エラー: {e}")
        return "<div>システムは稼働中です。更新をお待ちください。</div>"
