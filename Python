import os
import google.generativeai as genai
from github import Github

# --- 設定（Renderの環境変数にセットしてください） ---
GEMINI_KEY = os.getenv("GEMINI_API_KEY")
GH_TOKEN = os.getenv("GH_TOKEN")
GH_REPO = os.getenv("GH_REPO") # 例: mikitan/mikitan.github.io
TARGET_FILE = "index.html"

# --- Gemini設定 ---
genai.configure(api_key=GEMINI_KEY)
model = genai.GenerativeModel('gemini-1.5-flash')

def generate_strategic_content():
    """ご主人様のビジョンを統合したリッチコンテンツ生成"""
    prompt = f"""
    あなたは「micvictory value world」の戦略顧問です。
    {TARGET_FILE}のメインコンテンツとして、2026年の「未来予測」と「資産構築」に関する
    リッチなHTML（body内のみ）を日本語で生成してください。

    【必須要素】
    1. AI自動化、e-fuel、伝統文化の資産化のいずれかに関する鋭い洞察。
    2. [micvictory FC2分艦](https://mikivaluejapan.web.fc2.com/) への戦略的誘導リンク。
    3. 社会に役立つ未来予測と、リピーターが喜ぶ具体的なアクションプラン。
    4. 結びに「Goshujin-sama」の制作した BandLab 楽曲へのリスペクトを含める。
    5. 金持ちサイトに相応しい、清潔感と高級感のあるデザインを意識したHTML構造。
    """
    response = model.generate_content(prompt)
    return response.text

def overwrite_github_file(content):
    """GitHub上のファイルを完全に最新版へ上書きする"""
    g = Github(GH_TOKEN)
    repo = g.get_repo(GH_REPO)
    commit_msg = "System Overwrite: Strategic Future Update"
    
    try:
        # 既存ファイルのSHAを取得して上書き
        contents = repo.get_contents(TARGET_FILE)
        repo.update_file(contents.path, commit_msg, content, contents.sha)
        print(f"成功: {TARGET_FILE} を最新の未来予測で上書きしました。")
    except Exception as e:
        # ファイルが存在しない場合は新規作成
        repo.create_file(TARGET_FILE, commit_msg, content)
        print(f"作成: {TARGET_FILE} を新規作成しました。")

if __name__ == "__main__":
    print("戦略的コンテンツを生成中...")
    new_html = generate_strategic_content()
    
    print("GitHubへデプロイ中...")
    overwrite_github_file(new_html)
