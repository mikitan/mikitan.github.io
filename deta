<div id="mic-auto-post" style="
    background: #000; 
    color: #fff; 
    border: 1px solid #39FF14; 
    padding: 20px; 
    border-radius: 8px; 
    font-family: sans-serif;
    line-height: 1.8;
    max-width: 100%;
    box-shadow: 0 0 15px rgba(57, 255, 20, 0.2);
">
    <div id="post-date" style="font-size: 0.8em; color: #39FF14; margin-bottom: 10px;">Loading...</div>
    <h2 id="post-title" style="font-size: 1.4em; color: #FFD700; border-bottom: 1px solid #333; padding-bottom: 10px; margin-top: 0;">記事を読み込み中...</h2>
    <div id="post-body" style="font-size: 1em; color: #eee; margin-top: 15px;">
        </div>
</div>

<script>
(function() {
    // --- 【重要】ここをサイトに合わせて書き換える ---
    const SITE_KEY = "kensho"; // 例: kensho, recipe, gourmet, it_pc など
    const GITHUB_USER = "あなたのGitHubユーザー名"; 
    const REPO_NAME = "mikitan.github.io"; 

    const url = `https://raw.githubusercontent.com/${GITHUB_USER}/${REPO_NAME}/main/data/${SITE_KEY}_latest.json?t=${new Date().getTime()}`;

    fetch(url)
        .then(res => {
            if (!res.ok) throw new Error('Network response was not ok');
            return res.json();
        })
        .then(data => {
            document.getElementById('post-date').innerText = "更新日: " + data.date;
            document.getElementById('post-title').innerText = data.title;
            // 改行をHTMLタグに変換して表示
            document.getElementById('post-body').innerHTML = data.content
                .replace(/^# .*\n/, '') // タイトル重複削除
                .replace(/\n/g, '<br>');
        })
        .catch(err => {
            document.getElementById('post-title').innerText = "最新記事を準備中です";
            console.error('Fetch error:', err);
        });
})();
</script>
